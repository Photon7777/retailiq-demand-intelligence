# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_AUTHENTICATOR=
# For local Airflow, prefer key-pair auth:
# SNOWFLAKE_USER=RETAILIQ_AIRFLOW_USER
# SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
# SNOWFLAKE_PRIVATE_KEY_FILE=/opt/airflow/retailiq/secrets/snowflake/retailiq_airflow_key.p8
# SNOWFLAKE_ROLE=RETAILIQ_PIPELINE_ROLE
SNOWFLAKE_PRIVATE_KEY_FILE=
SNOWFLAKE_PRIVATE_KEY_FILE_PWD=
SNOWFLAKE_PASSCODE=
SNOWFLAKE_PASSCODE_IN_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Google Cloud Storage
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional Airflow local orchestration
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@example.com
RETAILIQ_AIRFLOW_TRUNCATE_FIRST=true
RETAILIQ_AIRFLOW_UPLOAD_GCS=false
RETAILIQ_AIRFLOW_GCS_PREFIX=retailiq/raw
